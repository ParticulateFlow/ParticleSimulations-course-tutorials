FoamFile
{
	version		2.0;
	format		ascii;
	class		dictionary;
	object		probesDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //



fields
(
   alpha.particles
   U.particles
   U.air
);

//writeControl   timeStep;
//writeInterval  1000;
writeControl    adjustableRunTime;
writeInterval   0.01;


// Locations to be probed.
probeLocations
(
	(0.0 0.0 0.5)
);

